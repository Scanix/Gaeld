##
## Gäld — Production environment template
## Copy to your shared .env location and fill in values marked CHANGE_ME
##

APP_NAME=Gäld
APP_ENV=production
APP_KEY=      # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://app.gaeld.ch
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=en,fr,de,it

LOG_CHANNEL=stack
LOG_LEVEL=error

SENTRY_LARAVEL_DSN=CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gaeld
DB_USERNAME=gaeld
DB_PASSWORD=CHANGE_ME

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@gaeld.ch"
MAIL_FROM_NAME="Gäld"

# SaaS — all flags true in production
FEATURE_SAAS=true
FEATURE_BANK_SYNC=true
FEATURE_AUTOMATION=true
FEATURE_MULTI_CURRENCY=true
FEATURE_API_ACCESS=true
FEATURE_AUTO_RECONCILIATION=true
FEATURE_RULE_ENGINE=true

# Stripe — get from dashboard.stripe.com
STRIPE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# EE Plugin
EE_TRIAL_DAYS=14
SAAS_ADMIN_EMAIL=CHANGE_ME@gaeld.ch

# Session cookie domain — share session across subdomains
SESSION_DOMAIN=.gaeld.ch

# Cookie consent domain — share consent across subdomains
VITE_COOKIE_DOMAIN=.gaeld.ch

# CORS — allow the landing site to share credentials with the API
CORS_ALLOWED_ORIGINS=https://app.gaeld.ch,https://gaeld.ch

# Misc
DOCS_BASE_URL=https://docs.gaeld.ch
SCOUT_DRIVER=database
PLUGINS_ENABLED=true

# Google Tag Manager
GTM_ID=GTM-W69RQCPN
