APP_NAME=Gäld
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=en,fr,de,it

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Sentry and Google Tag Manager are not used in community/self-hosted builds.
# They are configured in the private production deployment environment.
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_AUTH_TOKEN=   # used by Vite build to upload source maps
# SENTRY_ORG=
# SENTRY_PROJECT=

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=gaeld
DB_USERNAME=gaeld
DB_PASSWORD=

# Read replica (optional — leave empty to use a single host)
# DB_READ_HOST=

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

APP_PORT=8080
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="contact@gaeld.ch"
MAIL_FROM_NAME="${APP_NAME}"

# OCR — Receipt text recognition (requires tesseract-ocr installed on the server)
# sudo apt install tesseract-ocr tesseract-ocr-fra tesseract-ocr-deu
TESSERACT_BINARY=/usr/bin/tesseract
TESSERACT_LANG=deu+fra+eng
OCR_DAILY_LIMIT=3

# Feature Flags
FEATURE_SAAS=false
FEATURE_BANK_SYNC=false
FEATURE_AUTOMATION=false
FEATURE_MULTI_CURRENCY=false
FEATURE_API_ACCESS=false
FEATURE_AUTO_RECONCILIATION=false
FEATURE_RULE_ENGINE=false
FEATURE_ADVANCED_PERMISSIONS=false

# Session Security (defaults are secure — override only for local dev)
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# Session cookie domain — set to ".gaeld.ch" in production so that the
# session cookie is shared across subdomains (gaeld.ch, app.gaeld.ch).
# Leave empty for localhost development.
# SESSION_DOMAIN=.gaeld.ch

# Cookie consent domain — must match SESSION_DOMAIN so the consent cookie
# set on the landing site (gaeld.ch) is readable by the app (app.gaeld.ch).
# VITE_COOKIE_DOMAIN=.gaeld.ch

# CORS — comma-separated list of allowed origins (defaults to APP_URL)
# CORS_ALLOWED_ORIGINS=https://app.gaeld.ch,https://gaeld.ch,https://docs.gaeld.ch

# Stripe (required for SaaS / EE)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Enterprise Edition (SaaS)
# EE_TRIAL_DAYS=14
# SAAS_ADMIN_EMAIL=

# WebAuthn / Passkeys
WEBAUTHN_NAME="${APP_NAME}"
WEBAUTHN_ID=localhost
# WEBAUTHN_ORIGINS=

# Accounting
# ACCOUNTING_CURRENCY=CHF
# FISCAL_YEAR_START=01-01

# Documentation
DOCS_BASE_URL=http://localhost:3000

# Search
SCOUT_DRIVER=database
# When using Meilisearch set SCOUT_DRIVER=meilisearch — MEILISEARCH_KEY must be non-empty
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# Backup — path where backups are stored (shared with server backup system)
# BACKUP_PATH=/var/backups/gaeld
# BACKUP_ARCHIVE_PASSWORD=

# Activity / Audit Log
ACTIVITY_LOGGER_ENABLED=true

# Plugin System
PLUGINS_ENABLED=true

# Sanctum API tokens — global expiry backstop in minutes (10080 = 7 days)
SANCTUM_TOKEN_EXPIRATION=10080

# Google Tag Manager
GTM_ID=

# Slack Notifications (Horizon alerts)
SLACK_HORIZON_WEBHOOK=

# Schedule heartbeat (e.g. https://hc-ping.com/your-uuid)
SCHEDULE_HEARTBEAT_URL=
