APP_NAME=Gäld
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_AVAILABLE_LOCALES=en,fr,de,it,rm

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=gaeld
DB_USERNAME=gaeld
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

APP_PORT=8080
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@gaeld.ch"
MAIL_FROM_NAME="${APP_NAME}"

# Feature Flags
FEATURE_BANK_SYNC=false
FEATURE_SAAS=false
FEATURE_AUTOMATION=false
FEATURE_MULTI_CURRENCY=false
FEATURE_API_ACCESS=false

# Documentation
DOCS_BASE_URL=http://localhost:3000

# Plugin System
PLUGINS_ENABLED=true
