  "audit_findings": {
    "critical_blockers": [
      {
        "id": "CB-1",
        "severity": "HIGH",
        "status": "RESOLVED",
        "title": "CustomerApiController::destroy() has no FK constraint handling",
        "description": "Deleting a customer with linked invoices throws an unhandled QueryException (23503 FK violation) that surfaces as a 500 error to the API consumer. Customer model uses SoftDeletes which should prevent this, but the invoices table also references customer_id — if the DB has a strict FK constraint, it will fail.",
        "file": "app/Domains/Api/Controllers/CustomerApiController.php",
        "fix": "Added try-catch for QueryException checking PostgreSQL FK error codes (23503, 23000), returns 409 Conflict with localized message."
      },
      {
        "id": "CB-2",
        "severity": "MEDIUM",
        "status": "RESOLVED",
        "title": "per_page parameter unbounded in AccountApiController and BankAccountApiController",
        "description": "User can request per_page=999999, loading the entire table in one query. This is a DoS vector on endpoints with large datasets.",
        "file": "app/Domains/Api/Controllers/AccountApiController.php, BankAccountApiController.php",
        "fix": "per_page is now clamped to max 100 via min() in both controllers."
      },
      {
        "id": "CB-3",
        "severity": "MEDIUM",
        "title": "Hardcoded abilities list in ApiTokenController::abilities() and TokenSettingsController::index()",
        "description": "The /meta/abilities endpoint and the settings page both return a hardcoded array of abilities instead of deriving from the Permission enum. If new permissions are added to the enum, these lists will drift and clients won't see new abilities.",
        "file": "app/Domains/Api/Controllers/ApiTokenController.php, TokenSettingsController.php",
        "fix": "Use Permission::values() or equivalent."
      },
      {
        "id": "CB-4",
        "severity": "LOW",
        "title": "ApiInfoController status is always 'ok' — no real health check",
        "description": "The /api/v1/ endpoint always returns status: ok with hardcoded values. It performs no DB connectivity check, no queue check, no service health verification.",
        "file": "app/Domains/Api/Controllers/ApiInfoController.php",
        "fix": "Acceptable for a public endpoint, but document that it's not a real health check. The /up health route exists separately."
      }
    ],

    "incomplete_features": [
      {
        "id": "IF-1",
        "title": "InvoiceLine IDs exposed as auto-increment integers",
        "description": "All other API models use UUID for external IDs. InvoiceLine uses auto-increment integer, creating an inconsistency. Lines are nested (not directly addressable), so impact is low.",
        "file": "app/Domains/Api/Resources/InvoiceLineResource.php"
      },
      {
        "id": "IF-2",
        "title": "No API endpoint for invoice lifecycle operations",
        "status": "RESOLVED",
        "description": "Added finalize, cancel, record-payment, send, reminder, and credit-note endpoints to InvoiceApiController with corresponding API routes.",
        "file": "routes/api.php, app/Domains/Api/Controllers/InvoiceApiController.php"
      },
      {
        "id": "IF-3",
        "title": "No API endpoint for expense workflow operations",
        "status": "RESOLVED",
        "description": "Added approve and post-to-ledger endpoints to ExpenseApiController with corresponding API routes.",
        "file": "routes/api.php, app/Domains/Api/Controllers/ExpenseApiController.php"
      },
      {
        "id": "IF-4",
        "title": "No supplier API endpoints",
        "status": "RESOLVED",
        "description": "Created SupplierApiController with full CRUD (index, show, store, update, destroy), SupplierResource, and Store/Update request classes. Routes added to api.php.",
        "file": "routes/api.php, app/Domains/Api/Controllers/SupplierApiController.php"
      },
      {
        "id": "IF-5",
        "title": "Webhook event dispatching not wired for all events",
        "description": "WebhookEvent enum declares 14 events, but only accounting journal events have Laravel event classes. Invoice/customer/expense events must be dispatched manually from action classes — verify that every action dispatches the corresponding webhook event.",
        "status": "uncertain"
      }
    ],

    "hallucinations_and_fake_logic": [
      {
        "id": "HL-1",
        "title": "ApiInfoController: fake health endpoint",
        "description": "Returns hardcoded status:'ok' — not actually checking anything. The documentation URL points to docs.gaeld.ch which may or may not exist. This is not a hallucinated feature but a misleading implementation.",
        "severity": "LOW"
      },
      {
        "id": "HL-2",
        "title": "No hallucinated logic detected",
        "description": "All controllers, services, actions, DTOs, queries, jobs, and middleware contain real, working implementations. No stub methods, no TODO comments, no placeholder returns. The DispatchWebhookJob has full HMAC signing, retry logic, and response tracking. The InvoiceNumberGenerator produces real sequential numbers. The ValidWebhookUrl blocks real SSRF vectors.",
        "severity": "INFO"
      }
    ],

    "verified_working": [
      "Organization data isolation via BelongsToOrganization global scope",
      "Token ability enforcement via Gate::before in EnsureApiOrganization middleware",
      "UUID-to-FK resolution in Invoice/Expense controllers with validation-layer exists check",
      "Invoice number auto-generation with conflict retry",
      "Webhook HMAC signing and delivery job with retry backoff",
      "SSRF protection via ValidWebhookUrl (blocks RFC1918, loopback, metadata IPs)",
      "Sparse update support for invoices, expenses, customers, webhooks",
      "Feature flag gating via middleware for EE-only endpoints",
      "Soft-delete protection in expense/invoice delete actions"
    ]
  }
