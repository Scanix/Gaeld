#!/bin/sh
#
# Pre-push hook: runs Pint and PHPStan before pushing to production.
# Prevents pushing code that would fail CI lint/analyse stages.
#

REMOTE="$1"
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Only enforce on pushes to production
if [ "$BRANCH" != "production" ]; then
    exit 0
fi

echo "🔒 Pushing to production — running pre-push checks..."
echo ""

# 0. Drift guard: production must not be ahead of main
echo "🔍 [0/2] Checking production is not ahead of main..."
git fetch gitlab main --quiet 2>/dev/null || git fetch origin main --quiet 2>/dev/null || true
AHEAD=$(git log gitlab/main..HEAD --oneline 2>/dev/null | wc -l | tr -d ' ')
if [ "$AHEAD" -gt 0 ]; then
    echo ""
    echo "❌ Production is $AHEAD commit(s) ahead of main."
    echo "   Merge production → main and push main first, then retry."
    echo "   Run: git checkout main && git merge --ff-only production && git push gitlab main && git push origin main"
    echo "   Push to production aborted."
    exit 1
fi
echo "✅ Production is in sync with main."
echo ""

# 1. Pint (code style)
echo "🔍 [1/3] Running Pint..."
./vendor/bin/pint --test
PINT_EXIT=$?

if [ $PINT_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Pint found code style issues. Run 'composer format' to fix them."
    echo "   Push to production aborted."
    exit 1
fi

echo "✅ Pint passed."
echo ""

# 3. PHPStan (static analysis)
echo "🔍 [2/3] Running PHPStan..."
./vendor/bin/phpstan analyse --memory-limit=512M --no-progress
PHPSTAN_EXIT=$?

if [ $PHPSTAN_EXIT -ne 0 ]; then
    echo ""
    echo "❌ PHPStan found errors. Fix them before pushing to production."
    echo "   Push to production aborted."
    exit 1
fi

echo ""
echo "✅ All 3 pre-push checks passed. Pushing to production..."
exit 0
