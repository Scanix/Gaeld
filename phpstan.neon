includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    level: 7

    ignoreErrors:
        # The EE plugin is a private repo cloned only on deploy / local dev.
        # On open-source CI (GitHub) these classes are absent — suppress class.notFound.
        -
            identifier: class.notFound
            message: '#Plugins\\GaeldEE\\#'
            reportUnmatched: false

    excludePaths:
        - app/Console/
        - app/Domains/Api/Models/PersonalAccessToken.php
